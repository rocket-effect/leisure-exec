# .env — Root environment file for leisure-exec
# Loaded by every platform's docker-compose.yml via:  --env-file ../../.env
# Variables are prefixed per platform to avoid collisions.

# ── Claude Code UI ─────────────────────────────────────────────────────────────
CLAUDECODE_IMAGE=hasnaina1/claudecodeui:basic
CLAUDECODE_CONTAINER=claudecode
CLAUDECODE_RESTART=unless-stopped
CLAUDECODE_PORT_APP=3033:3001
CLAUDECODE_PORT_VITE=5173:5173
CLAUDECODE_USER=1000:1000
CLAUDECODE_COMMAND=npm start

# ── Ghost CMS ──────────────────────────────────────────────────────────────────
GHOST_IMAGE=ghost:bookworm
GHOST_CONTAINER=ghost
GHOST_RESTART=always
GHOST_PORT=2367:2368
GHOST_URL=http://ghost.demo.rocketeffect.com

# Ghost → MySQL connection
GHOST_DB_HOST=host.docker.internal
GHOST_DB_PORT=3306
GHOST_DB_USER=root
GHOST_DB_PASSWORD=
GHOST_DB_NAME=ghost-cms

# ── MySQL (standalone server — no default DB created) ────────────────────────────
MYSQL_IMAGE=mysql:8.4
MYSQL_RESTART=unless-stopped
MYSQL_PORT=3307:3306
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=app
MYSQL_PASSWORD=apppassword

# ── PostgreSQL (standalone server — no default DB created) ──────────────────────
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_RESTART=unless-stopped
POSTGRES_PORT=5435:5432
POSTGRES_USER=app
POSTGRES_PASSWORD=apppassword
